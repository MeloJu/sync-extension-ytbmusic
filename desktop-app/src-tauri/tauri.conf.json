{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YT Music Sync",
  "version": "0.1.0",
  "identifier": "com.melouju.ytmusicsync",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "label": "settings",
        "url": "settings.html",
        "title": "YT Music Sync — Configurações",
        "width": 320,
        "height": 320,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": { "type": "downloadBootstrapper" }
    }
  }
}
